# =============================================================================
# FisioPilates — variáveis de ambiente
# Copie para .env.local e preencha. NUNCA commite .env.local.
# Detalhes de cada variável em docs/plan/06-infra-deploy.md
# =============================================================================

# --- App -------------------------------------------------------------------
# URL pública da aplicação (usada em callbacks de auth e no worker de ingestão).
# Na Vercel: defina como a URL real do deployment (ex.: https://seu-projeto.vercel.app
# ou o domínio custom) — NUNCA localhost em Production/Preview.
APP_URL=http://localhost:3000

# DATABASE_URL: só usada localmente para aplicar migrations via `psql`/Supabase
# CLI (npm run db:push). NÃO é lida pelo código da aplicação — não precisa ser
# configurada como env var na Vercel.

# --- Supabase --------------------------------------------------------------
# Projeto Supabase (região sa-east-1). Painel > Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SECRETA — só no servidor (route handlers / jobs). Bypassa RLS: use com filtro
# manual de tenant_id. Nunca exponha no cliente.
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenRouter (LLM + embeddings) -----------------------------------------
OPENROUTER_API_KEY=
# Modelo principal — PINAR o ID explícito, nunca usar alias "latest".
OPENROUTER_MODEL=anthropic/claude-sonnet-5
# Fallback automático quando o principal falha (extraBody.models).
OPENROUTER_MODEL_FALLBACK=anthropic/claude-sonnet-4.6
# Modelo barato para tarefas auxiliares (reescrita de query, títulos, sumarização).
OPENROUTER_MODEL_CHEAP=anthropic/claude-haiku-4.5

# --- Embeddings (via endpoint OpenAI-compatível do OpenRouter) -------------
# Trocar de modelo exige RE-EMBEDDING de toda a base; a dimensão trava a coluna.
EMBEDDINGS_MODEL=openai/text-embedding-3-small
EMBEDDINGS_DIM=1536

# --- QStash (Upstash) — fila de ingestão da base de conhecimento -----------
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# --- Tavily — busca web em tempo real (fallback do RAG) --------------------
TAVILY_API_KEY=

# --- YouTube Data API — reproduzir vídeo do exercício DENTRO do app (opcional)
# Sem a chave, o app abre a busca no YouTube/TikTok em nova aba. Com a chave,
# resolve o vídeo mais relevante e o reproduz embutido. Crie em:
# https://console.cloud.google.com (habilite "YouTube Data API v3").
YOUTUBE_API_KEY=

# --- Stripe (Billing) ------------------------------------------------------
# Secret + webhook secret do Dashboard > Developers > API keys / Webhooks.
# Use sk_test_/whsec_... em dev; sk_live_/whsec_... em produção.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Price IDs (crie no Dashboard > Products ou via API). Em dev, deixe em branco
# se você não pretende rodar checkout — o handler de webhook só é chamado se
# você apontar o CLI/URL do webhook para cá.
STRIPE_PRICE_ESSENCIAL=price_xxx
STRIPE_PRICE_PROFISSIONAL=price_xxx
STRIPE_PRICE_CLINICA=price_xxx
# Pay-as-you-go: 1 assinatura com 3 items metered (chat/report/vision).
STRIPE_PRICE_PAYG_BASE=price_xxx
STRIPE_PRICE_PAYG_CHAT=price_xxx
STRIPE_PRICE_PAYG_REPORT=price_xxx
STRIPE_PRICE_PAYG_VISION=price_xxx
